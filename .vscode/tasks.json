{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cargo build",
      "type": "shell",
      "command": "cargo build",
      "group": "build"
    },
    {
      "label": "cargo build --release",
      "type": "shell",
      "command": "cargo build --release",
      "group": "build"
    },
    {
      "label": "run server (debug)",
      "type": "shell",
      "command": "cargo run -- --config config.yaml",
      "isBackground": true
    }
  ]
}
